{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tuno",
  "main": "src/tuno/cloudflare/worker.py",
  "base_dir": "src",
  "compatibility_date": "2026-05-12",
  "compatibility_flags": ["python_workers"],
  "workers_dev": true,
  "python_modules": {
    "excludes": ["**/*.pyc", "**/__pycache__"]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "TUNO_GAME",
        "class_name": "TunoGame"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["TunoGame"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
