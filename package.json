{
    "name": "tuno",
    "version": "1.0.1",
    "private": true,
    "scripts": {
        "bump": "uv run python scripts/bump_version.py",
        "dev:client": "uv run python -m tuno.client",
        "dev:worker": "uv run pywrangler dev",
        "deploy:worker": "uv run pywrangler deploy",
        "format": "uv run python -m ruff format .",
        "tag": "sh scripts/tag.sh",
        "tests": "uv run python -m unittest discover -s tests -v"
    }
}
